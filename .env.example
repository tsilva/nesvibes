# Browser/runtime DSN. Used by the client and as a server fallback.
PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional server-only DSN override for SSR and hooks.
SENTRY_DSN=https://examplePrivateKey@o0.ingest.sentry.io/0
# Optional local override. Production enables Sentry automatically.
PUBLIC_SENTRY_ENABLED=false
# Read-only or release-upload token, depending on your workflow.
SENTRY_AUTH_TOKEN=sntrys_your_token_here
SENTRY_ORG=tsilva
SENTRY_PROJECT=nesvibes
SENTRY_BASE_URL=https://sentry.io
